{
  "expo": {
    "name": "XENOTIF®",
    "slug": "xenotif",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xenotif",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0F",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xenotif.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "XENOTIF® accède à vos données de santé pour suivre vos entraînements et votre progression.",
        "NSHealthUpdateUsageDescription": "XENOTIF® enregistre vos séances d'entraînement.",
        "NSBluetoothAlwaysUsageDescription": "XENOTIF® utilise le Bluetooth pour se connecter à votre montre et capteurs fitness.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": ["health-records"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0B0F"
      },
      "package": "com.xenotif.app",
      "versionCode": 1,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF4500"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
