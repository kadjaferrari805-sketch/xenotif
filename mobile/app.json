{
  "expo": {
    "name": "XENOTIF®",
    "slug": "xenotif",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "xenotif",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0F",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xenotif.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "XENOTIF® accède à vos données de santé pour suivre vos entraînements et votre progression.",
        "NSHealthUpdateUsageDescription": "XENOTIF® enregistre vos séances d'entraînement.",
        "NSBluetoothAlwaysUsageDescription": "XENOTIF® utilise le Bluetooth pour se connecter à votre montre et capteurs fitness.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": ["health-records"]
      }
    },
    "android": {
      "package": "com.xenotif.app",
      "versionCode": 1,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-notifications", { "color": "#FF4500" }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b6236a1f-a958-4110-b8da-23cd447345b4"
      }
    }
  }
}
